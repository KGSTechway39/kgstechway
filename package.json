    "@vercel/analytics": "^1.5.0",
    "bootstrap": "^5.3.8",
    "framer-motion": "^12.23.24",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.1",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.9.4",
    "vercel": "^48.6.0"
  },
